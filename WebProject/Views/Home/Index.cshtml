<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --border: #1e1e2e;
            --accent: #c8ff3e;
            --accent-dim: rgba(200,255,62,0.12);
            --muted: #3a3a52;
            --text: #e8e8f0;
            --text-dim: #6b6b8a;
            --red: #ff4e6a;
            --blue: #4ea8ff;
            --orange: #ffb347;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Mono', monospace;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ── */
        aside {
            width: 220px;
            min-height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 32px 0;
            flex-shrink: 0;
            animation: slideIn .5s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes slideIn {
            from {
                transform: translateX(-24px);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .logo {
            padding: 0 24px 32px;
            border-bottom: 1px solid var(--border);
        }

        .logo-mark {
            width: 36px;
            height: 36px;
            background: var(--accent);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 16px;
            color: #0a0a0f;
            letter-spacing: -1px;
            margin-bottom: 10px;
        }

        .logo h1 {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-dim);
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        nav {
            padding: 24px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 12px;
            margin-bottom: 8px;
        }

        nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 6px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: .02em;
            transition: all .15s;
            margin-bottom: 2px;
        }

        nav form button {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 6px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: .02em;
            transition: all .15s;
            background: var(--bg);
            box-shadow: none;
            border: none;
            border-width: 0px;
            border-style: solid;
            width: 195px !important;
            margin-left: -13px !important;
        }

        nav form {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 6px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: .02em;
            transition: all .15s;
            width: 300px !important;
        }

            nav a:hover {
                color: var(--text);
                background: var(--border);
            }

            nav a.active {
                color: var(--accent);
                background: var(--accent-dim);
            }

            nav a .icon {
                font-size: 15px;
                width: 18px;
                text-align: center;
            }

            nav form button:hover {
                color: var(--text);
                background: var(--border);
            }

            nav form button {
                font-size: 15px;
                width: 18px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--border);
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6e6ef0, var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .user-info small {
            display: block;
            font-size: 11px;
            color: var(--text-dim);
        }

        .user-info strong {
            display: block;
            font-size: 12px;
            font-family: 'Syne', sans-serif;
            font-weight: 600;
            color: var(--text);
        }

        /* ── MAIN ── */
        main {
            flex: 1;
            padding: 40px 44px;
            overflow-y: auto;
            animation: fadeUp .6s cubic-bezier(.22,1,.36,1) .1s both;
        }

        @@keyframes fadeUp {
            from {
                transform: translateY(16px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -.02em;
        }

            .page-title span {
                color: var(--accent);
            }

        .topbar-right {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .badge {
            background: var(--accent-dim);
            color: var(--accent);
            border: 1px solid rgba(200,255,62,0.25);
            font-size: 11px;
            padding: 5px 12px;
            border-radius: 20px;
            letter-spacing: .06em;
        }

        .btn-ghost {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-dim);
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            padding: 7px 16px;
            border-radius: 6px;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-ghost:hover {
                color: var(--text);
                border-color: var(--muted);
            }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 36px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 22px;
            position: relative;
            overflow: hidden;
            transition: border-color .2s;
        }

            .stat-card:hover {
                border-color: var(--muted);
            }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--accent-color, var(--accent));
                opacity: .7;
            }

        .stat-label {
            font-size: 11px;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 10px;
        }

        .stat-value {
            font-family: 'Syne', sans-serif;
            font-size: 30px;
            font-weight: 800;
            letter-spacing: -.03em;
            margin-bottom: 8px;
        }

        .stat-delta {
            font-size: 11px;
            color: var(--text-dim);
        }

            .stat-delta .up {
                color: var(--accent);
            }

            .stat-delta .dn {
                color: var(--red);
            }

        .stat-icon {
            position: absolute;
            top: 18px;
            right: 18px;
            font-size: 22px;
            opacity: .18;
        }

        /* ── TABLE SECTION ── */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .section-title {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: .02em;
        }

            .section-title span {
                font-family: 'DM Mono', monospace;
                font-weight: 400;
                font-size: 12px;
                color: var(--text-dim);
                margin-left: 8px;
            }

        .btn-accent {
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            font-weight: 500;
            padding: 8px 18px;
            border-radius: 6px;
            cursor: pointer;
            letter-spacing: .04em;
            transition: opacity .15s, transform .1s;
        }

            .btn-accent:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

        .table-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
        }

            .search-bar input {
                background: transparent;
                border: none;
                outline: none;
                font-family: 'DM Mono', monospace;
                font-size: 13px;
                color: var(--text);
                flex: 1;
            }

                .search-bar input::placeholder {
                    color: var(--muted);
                }

            .search-bar .search-icon {
                color: var(--muted);
                font-size: 14px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            font-size: 11px;
            font-weight: 400;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text-dim);
            text-align: left;
            padding: 12px 20px;
            background: rgba(255,255,255,.02);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
            cursor: default;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: rgba(255,255,255,.025);
            }

        td {
            padding: 14px 20px;
            font-size: 13px;
            color: var(--text);
            vertical-align: middle;
        }

        .cell-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .mini-avatar {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .cell-name {
            font-weight: 500;
        }

        .cell-email {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 1px;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            letter-spacing: .04em;
            white-space: nowrap;
        }

            .status-pill::before {
                content: '';
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: currentColor;
            }

        .s-active {
            background: rgba(200,255,62,.1);
            color: var(--accent);
        }

        .s-pending {
            background: rgba(255,179,71,.1);
            color: var(--orange);
        }

        .s-inactive {
            background: rgba(255,78,106,.1);
            color: var(--red);
        }

        .role-tag {
            background: rgba(78,168,255,.1);
            color: var(--blue);
            font-size: 11px;
            padding: 3px 9px;
            border-radius: 4px;
            letter-spacing: .04em;
        }

        .action-btn {
            background: none;
            border: 1px solid var(--border);
            color: var(--text-dim);
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            padding: 5px 12px;
            border-radius: 5px;
            cursor: pointer;
            transition: all .13s;
            margin-right: 4px;
        }

            .action-btn:hover {
                color: var(--text);
                border-color: var(--muted);
            }

            .action-btn.del:hover {
                color: var(--red);
                border-color: var(--red);
            }

        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 20px;
            border-top: 1px solid var(--border);
            font-size: 12px;
            color: var(--text-dim);
        }

        .pager {
            display: flex;
            gap: 4px;
        }

        .page-btn {
            background: none;
            border: 1px solid var(--border);
            color: var(--text-dim);
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            width: 30px;
            height: 30px;
            border-radius: 5px;
            cursor: pointer;
            transition: all .13s;
        }

            .page-btn:hover {
                color: var(--text);
                border-color: var(--muted);
            }

            .page-btn.current {
                background: var(--accent-dim);
                color: var(--accent);
                border-color: rgba(200,255,62,.3);
            }

        /* staggered rows */
        tbody tr {
            animation: rowIn .35s cubic-bezier(.22,1,.36,1) both;
        }

            tbody tr:nth-child(1) {
                animation-delay: .05s;
            }

            tbody tr:nth-child(2) {
                animation-delay: .10s;
            }

            tbody tr:nth-child(3) {
                animation-delay: .15s;
            }

            tbody tr:nth-child(4) {
                animation-delay: .20s;
            }

            tbody tr:nth-child(5) {
                animation-delay: .25s;
            }

            tbody tr:nth-child(6) {
                animation-delay: .30s;
            }

        @@keyframes rowIn {
            from {
                opacity: 0;
                transform: translateX(-8px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* stat cards stagger */
        .stat-card:nth-child(1) {
            animation: fadeUp .5s .15s both;
        }

        .stat-card:nth-child(2) {
            animation: fadeUp .5s .22s both;
        }

        .stat-card:nth-child(3) {
            animation: fadeUp .5s .29s both;
        }

        .stat-card:nth-child(4) {
            animation: fadeUp .5s .36s both;
        }
    </style>
</head>
<body>

