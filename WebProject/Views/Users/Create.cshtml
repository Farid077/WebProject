    <form method="post" asp asp-action="Create" class="form-body">
      @* <div asp-validation-summary="All" class="err-msg"></div> *@
      <div class="form-row single">
        <div class="field" id="f-first">
          <label asp-for="Username">Username</label>
          <input asp-for="Username" type="text" id="first-name" name="Username" placeholder="e.g. Maria">
          <span asp-validation-for="Username" class="err-msg"></span>
        </div>
        @* <div class="field" id="f-last">
          <label>Last Name</label>
          <input type="text" id="last-name" placeholder="e.g. Reyes">
          <span class="err-msg">Required</span>
        </div> *@
      </div>

      @* <div class="form-row">
        <div class="field" id="f-email">
          <label>Email Address</label>
          <input type="email" id="email" placeholder="user@example.com">
          <span class="err-msg">Enter a valid email</span>
        </div>
        <div class="field">
          <label>Phone (optional)</label>
          <input type="text" id="phone" placeholder="+1 555 000 0000">
        </div>
      </div> *@

      <div class="form-row single">
        <div class="field" id="f-role">
          <label asp-for="Role">Role</label>
          <select asp-for="Role" id="role">
            <option value="">Select role...</option>
            @foreach(var role in Model.RoleOptions)
            {
                <option selected="@(role == Model.Role ? role : null)" value="@role">@role</option>
            }
            @* <option value="Super Admin">Super Admin</option> *@
          </select>
          <span asp-validation-for="Role" class="err-msg"></span>
        </div>

        @* ---------------------------------------------------------------------------------------------------------------------- *@
        @* <div class="field">
          <label>Status</label>
          <select id="status">
            <option value="active">Active</option>
            <option value="pending">Pending</option>
            <option value="inactive">Inactive</option>
          </select>
        </div> *@
      </div>

      <div class="form-row single">
        <div class="field" id="f-pw">
          <label asp-for="Password">Password</label>
          <input asp-for="Password" name="Password" type="password" id="password" placeholder="Min. 8 characters">
          <span class="input-icon toggle-pw" style="font-size: 12px;" id="pw-toggle" onclick="togglePw()">◷ show password</span>
          <span asp-validation-for="Password" class="err-msg"></span>
        </div>
      </div>

      <div class="form-row single">
        <div class="field" id="f-pw">
          <label asp-for="ConfirmPassword">Confirm Password</label>
          <input asp-for="ConfirmPassword" name="ConfirmPassword" type="password" id="confirmpassword" placeholder="Confirm password">
          <span class="input-icon toggle-pw" style="font-size: 12px;" id="pw-toggle-confirm" onclick="togglePwConfirm()">◷ show password</span>
          <span asp-validation-for="ConfirmPassword" class="err-msg"></span>
        </div>
      </div>

      <button type="submit" class="btn-save">Create User</button>
    </form>

  </div>
</main>

