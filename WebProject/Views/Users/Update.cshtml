<div class="overlay" id="overlay" onclick="closeDelete(event)">
  <div class="dialog">
    <div class="dialog-icon">⚠</div>
    <h3>Delete this user?</h3>
    <p>This will permanently remove <strong id="dialog-name">Maria Reyes</strong> and all associated data. This action cannot be undone.</p>
    <div class="dialog-btns">
      <button class="btn-cancel" onclick="closeDelete()">Cancel</button>
      <button class="btn-confirm-delete" onclick="confirmDelete()">Yes, Delete</button>
    </div>
  </div>
</div> *@

