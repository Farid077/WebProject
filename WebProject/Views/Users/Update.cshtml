      <div class="avatar">JD</div>
      <div class="user-info">
        <strong>J. Doe</strong>
        <small>Super Admin</small>
      </div>
    </div>
  </div> *@
</aside>

<main>
  <div class="topbar">
    <div class="breadcrumb">
      <a asp-action="Index" asp-controller="Home">Dashboard</a>
      <span class="sep">/</span>
      <a asp-action="Index">Users</a>
      <span class="sep">/</span>
      <span class="current">Edit User</span>
    </div>
    @* <span class="last-edited">Last edited <span>2 days ago</span></span> *@
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-icon">✎</div>
      <div>
        <div class="card-title">Edit User</div>
        <div class="card-sub">Update the details for this account.</div>
      </div>
    </div>

    <!-- Avatar preview -->
    <div class="avatar-row">
                <div class="big-avatar" id="big-avatar">@ViewData["Id"]?.ToString()?.ToUpper()[0]@ViewData["Id"]?.ToString()?.ToUpper()[1]</div>
      <div class="avatar-meta">
        <strong id="preview-name">@ViewData["Id"]?.ToString()</strong>
        @* <small id="preview-email">m.reyes@example.com</small> *@
        @* <span class="status-pill s-active">Active</span> *@
      </div>
    </div>

    <form asp-action="Update" asp-controller="Users" method="post" asp-route-id="@ViewData["Id"]?.ToString()">
        @* <div asp-validation-summary="All" class="err-msg"></div> *@
        <div class="form-body">
          @* <div class="form-row single">
            <div class="field" id="f-first">
              <label>Username</label>
              <input name="Username" type="text" id="first-name" value="@ViewData["Id"]?.ToString()">
              <span asp-validation-for="Username" class="err-msg"></span>
            </div>
          </div> *@

          <div class="form-row single">
            <div class="field" id="f-role">
              <label asp-for="Role">Role</label>
              <select asp-for="Role" id="role">
                <option value="">Select role...</option>
                @foreach(var role in Model.RoleOptions)
                {
                    <option selected="@(role == Model.Role ? role : null)" value="@role">@role</option>
                }
              </select>
              <span asp-validation-for="Role" class="err-msg"></span>
            </div>
          </div>

          <div class="form-row single">
            <div class="field">
              <label asp-for="Password" >New Password <span style="color:var(--muted);font-size:10px;">(leave blank to keep current)</span></label>
              <input asp-for="Password" name="Password" type="password" id="password" placeholder="Leave blank to keep current">
              <span class="input-icon toggle-pw" style="font-size: 12px;" id="pw-toggle" onclick="togglePw()">◷ show password</span>
              <span asp-validation-for="Password" class="err-msg"></span>
            </div>
          </div>

          <div class="form-row single">
            <div class="field">
              <label asp-for="ConfirmPassword" >Confirm Password <span style="color:var(--muted);font-size:10px;"></span></label>
              <input asp-for="ConfirmPassword" name="ConfirmPassword" type="password" id="confirmpassword" placeholder="Confirm Password">
              <span class="input-icon toggle-pw" style="font-size: 12px;" id="pw-toggle-confirm" onclick="togglePwConfirm()">◷ show password</span>
              <span asp-validation-for="ConfirmPassword" class="err-msg"></span>
            </div>
          </div>

          @* <div class="form-row single">
            <div class="field">
              <label>Notes (optional)</label>
              <textarea id="notes">Primary content editor for the EU region.</textarea>
            </div>
          </div> *@
        </div>

        <div class="card-footer">
          @* <button class="btn-cancel">Cancel</button> *@
          <div class="footer-right">
            @* <button class="btn-delete" onclick="openDelete()">Delete User</button> *@
            <button type="submit" class="btn-save">Save Changes</button>
          </div>
        </div>
    </form>
  </div>
</main>

