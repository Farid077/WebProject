@model DepartmentCreateVM

@{
    ViewData["Title"] = "Add Department";
    ViewData["ActivePage"] = "Departments";
}

<div class="topbar">
    <div class="breadcrumb">
        <a asp-action="Index" asp-controller="Home">Dashboard</a>
        <span class="sep">/</span>
        <a asp-action="Index">Departments</a>
        <span class="sep">/</span>
        <span class="current">Add Department</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-icon">◈</div>
        <div>
            <div class="card-title">Add New Department</div>
            <div class="card-sub">Fill in the details to create a new Department.</div>
        </div>
    </div>

    <form method="post" asp-action="Create" class="form-body" id="form">
        @Html.AntiForgeryToken()
        <div class="form-row single">
            <div class="field">
                <label asp-for="Name">Department Name</label>
                <input asp-for="Name" type="text" name="Name" placeholder="e.g. Maliyyə">
                <span asp-validation-for="Name" class="err-msg"></span>
            </div>
        </div>
        <button type="submit" class="btn-save">Create Department</button>
    </form>
</div>