@model List<UrgencyManagementVM>

@{
    ViewData["Title"] = "Urgencies";
    ViewData["ActivePage"] = "Urgencies";
}

<div class="topbar">
    <div class="page-title">Issue Urgencies</div>
</div>

<div class="stats-grid">
    <div class="stat-card" style="--accent-color: var(--accent)">
        <div class="stat-icon">◈</div>
        <div class="stat-label">Total Urgencies</div>
        <div class="stat-value">@Model.Count()</div>
    </div>
</div>

<div class="section-header">
    <div class="section-title">Urgency Management</div>
    <a style="text-decoration:none" asp-action="Create" class="btn-accent">+ New Urgency</a>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var urgency in Model)
            {
                <tr>
                    <td>
                        <div class="cell-Issue">
                            @* <div class="mini-avatar" style="background:rgba(200,255,62,.15);color:var(--accent)">
                                @Issue.ame.ToUpper()[0]@Issue.Issuename.ToUpper()[1]
                            </div> *@
                            <div>
                                <div class="cell-name">@urgency.Name</div>
                            </div>
                        </div>
                    <td>@urgency.Days Days @urgency.Hours Hours @urgency.Minutes Minutes</td>
                    <td style="display:flex;">
                        <a asp-action="Update" asp-route-id="@urgency.Id" class="action-btn edit" style="text-decoration:none;">Edit</a>
                        <form method="POST" class="action" asp-action="Delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@urgency.Id" />
                            <button class="action-btn del" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>