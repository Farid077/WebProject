@model List<IssueManagementVM>

@{
    ViewData["Title"] = "Issues";
    ViewData["ActivePage"] = "Issues";
}

<div class="topbar">
    <div class="page-title">Issues</div>
</div>

<div class="stats-grid">
    <div class="stat-card" style="--accent-color: var(--accent)">
        <div class="stat-icon">◈</div>
        <div class="stat-label">Total Issues</div>
        <div class="stat-value">@Model.Count()</div>
    </div>
</div>

<div class="section-header">
    <div class="section-title">Issue Management</div>
    <a style="text-decoration:none" asp-action="Create" class="btn-accent">+ New Issue</a>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Category</th>
                <th>SubCategory</th>
                <th>Reporter Name</th>
                <th>Assignee Name</th>
                <th>Status</th>
                <th>Reported Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var issue in Model)
            {
                <tr>
                    <td>
                        <div class="cell-Issue">
                            <div class="mini-avatar" style="background:rgba(200,255,62,.15);color:var(--accent)">
                                @issue.Category.ToUpper()[0]@issue.Category.ToUpper()[1]
                            </div>
                            <div>
                                <div class="cell-name">@issue.Category</div>
                            </div>
                        </div>
                    </td>
                    <td><span class="role-tag">@issue.SubCategory</span></td>
                    <td>@issue.ReporterName</td>
                    <td>@issue.AssigneeName</td>
                    <td>@issue.Status</td>
                    <td>@issue.CreatedTime</td>
                    <td style="display:flex;">
                        <a asp-action="Update" class="action-btn edit" style="text-decoration:none;">Edit</a>
                        <form method="POST" class="action">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@issue.Id" />
                            <button class="action-btn del" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
