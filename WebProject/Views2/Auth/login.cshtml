</div>

<script>
  function togglePw() {
    const input = document.getElementById('password');
    const icon  = document.getElementById('pw-toggle');
    if (input.type === 'password') {
      input.type = 'text';
      icon.textContent = '◉';
    } else {
      input.type = 'password';
      icon.textContent = '◷';
    }
  }

